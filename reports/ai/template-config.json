    "ai": {
      "id": "ai",
      "name": "AI Supply Chain Intelligence",
      "description": "Template for AI supply-chain and ecosystem research.",
      "defaultGroupPopupTable": {
        "buttonLabel": "▦ Revenue",
        "title": "Revenue Table",
        "subtitle": "Group finance snapshot",
        "note": "Revenue and CapEx values are extracted from matched story text for the selected group.",
        "rowSource": {
          "type": "companies"
        },
        "columns": [
          {
            "key": "company",
            "label": "Company",
            "valueDescription": "Tracked company name for this group",
            "derive": { "type": "company" }
          },
          {
            "key": "revenue",
            "label": "Revenue",
            "valueDescription": "First revenue-like mention in a matched story (revenue, ARR, funding, valuation, or profit)",
            "derive": { "type": "financeValue", "metric": "revenue" }
          },
          {
            "key": "capex",
            "label": "Capex",
            "valueDescription": "First capital spending mention from matched stories",
            "derive": { "type": "financeValue", "metric": "capex" }
          },
          {
            "key": "mentions",
            "label": "Mentions",
            "valueDescription": "Count of matched stories that mention the company",
            "derive": { "type": "mentions" }
          },
          {
            "key": "period",
            "label": "Period",
            "valueDescription": "Reported period inferred from story text (e.g., quarter/year)",
            "derive": { "type": "financePeriod", "metrics": ["revenue", "capex"] }
          },
          {
            "key": "vsPrior",
            "label": "vs. Prior",
            "valueDescription": "Comparison versus prior report (placeholder until trend storage is added)",
            "derive": { "type": "literal", "value": "—" }
          }
        ]
      },
